# ══════════════════════════════════════════════════
# Copiar este archivo como .env y rellenar los valores
# El archivo .env NO debe subirse al repositorio
# ══════════════════════════════════════════════════

# ── Dispositivo biométrico ZK ──────────────────────
ZK_IP=IP_ADDRESS
ZK_PORT=4370
ZK_PASSWORD=PASSWORD
ZK_TIMEOUT=5
# Usar UDP en lugar de TCP (más rápido en red local, probar antes de activar)
ZK_UDP=false

# ── Sincronización automática ──────────────────────
# SYNC_AUTO=true activa el scheduler de fondo
SYNC_AUTO=false
# Hora del sync nocturno diario (formato HH:MM)
SYNC_HORA_NOCTURNA=00:30
# Intervalo del sync periódico durante la jornada (minutos)
SYNC_INTERVALO_MIN=30

# ── Rutas de datos (dentro del contenedor Docker) ──
DATA_DIR=/data
DB_PATH=/data/asistencias.db
UPLOAD_FOLDER=/data/uploads
REPORTS_FOLDER=/data/reports

# ── Flask ──────────────────────────────────────────
# Cambiar por una clave aleatoria y segura en producción
FLASK_SECRET_KEY=cambiar_esto_por_una_clave_larga_y_segura
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
# Nunca activar debug en producción (Docker)
FLASK_DEBUG=false

# ── Autenticación de acceso ─────────────────────────
# Dejar vacío para deshabilitar la autenticación (modo desarrollo)
# Para generar el hash: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('tu_clave'))"
APP_PASSWORD_HASH=
