# ══════════════════════════════════════════════════════════════════════════
# Copiar este archivo como .env y rellenar los valores
# El archivo .env NO debe subirse al repositorio git
# ══════════════════════════════════════════════════════════════════════════

# ── Información del Sistema ────────────────────────────────────────────────
NOMBRE_SISTEMA=Informes Biométricos
NOMBRE_INSTITUCION=NOMBRE_DE_TU_INSTITUCION

# ── Rutas de datos ─────────────────────────────────────────────────────────
# En Docker usar /data; en desarrollo local dejar como está
DATA_DIR=/data
UPLOAD_FOLDER=/data/uploads
REPORTS_FOLDER=/data/reports

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=asistencias_user
POSTGRES_PASSWORD=cambiar_esto_en_produccion
POSTGRES_DB=asistencias_db
# En Docker: el host es el nombre del servicio 'db'
# En desarrollo local: usar localhost
DATABASE_URL=postgresql://asistencias_user:cambiar_esto_en_produccion@db:5432/asistencias_db

# Tenant activo en esta instalación (slug del schema en PostgreSQL)
TENANT_DEFAULT=istpet

# Clave AES-256 para cifrar contraseñas de dispositivos biométricos en la BD
# Generar con: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
DB_ENCRYPTION_KEY=generar_clave_aleatoria_con_comando_de_arriba

# ── Flask ──────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=cambiar_esto_por_una_clave_larga_y_segura
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
# NUNCA activar debug en producción (Docker)
FLASK_DEBUG=false

# ── Autenticación — Fase 2 ─────────────────────────────────────────────────
# La autenticación usa usuarios en public.usuarios con bcrypt.
# Crear el primer superadmin con:
#   python crear_superadmin.py --email admin@inst.edu.ec --nombre "Administrador"

# Duración de la sesión en horas (default: 8)
SESSION_LIFETIME_HOURS=8

# ── Superadmin Inicial (solo para primera instalación) ──────────────────────
# Estas variables se usan una sola vez al iniciar el sistema por primera vez
INITIAL_SUPERADMIN_EMAIL=admin@tuinstitucion.edu.ec
INITIAL_SUPERADMIN_PASSWORD=elige_una_clave_segura

# ── Correo electrónico (SMTP) ──────────────────────────────────────────────
# Requerido para: envío de informes PDF, alertas de dispositivos
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notificaciones@tuinstitucion.edu.ec
# Para Gmail/Outlook usar una Contraseña de Aplicación (App Password), no la contraseña real
SMTP_PASSWORD=tu_contraseña_o_app_password
SMTP_FROM=notificaciones@tuinstitucion.edu.ec
# true para puerto 587 con STARTTLS; false para puerto 465 con SSL directo
SMTP_USE_TLS=true

# ── Sincronización automática — Fase 6/7 ──────────────────────────────────
# SYNC_AUTO=true activa el scheduler de fondo (requiere reiniciar el servidor)
SYNC_AUTO=false
# Hora de la sync nocturna completa diaria (formato HH:MM, 24h)
SYNC_HORA_NOCTURNA=02:00
# Intervalo de la sync incremental durante el día (en horas, default: 2)
SYNC_INTERVALO_HORAS=2

# ── Alertas de dispositivos — Fase 7 ──────────────────────────────────────
# Email del administrador técnico que recibe alertas cuando un dispositivo
# falla 3 syncs consecutivas. Requiere SMTP configurado arriba.
# Dejar vacío para deshabilitar alertas por correo.
ADMIN_EMAIL=

# ── Dispositivo biométrico ZK (legacy / fallback) ─────────────────────────
# Estas variables son el fallback si el dispositivo no tiene contraseña
# registrada en la BD. En Fase 6+ los dispositivos se gestionan desde la UI
# en /admin/dispositivos — no es necesario configurar esto manualmente.
ZK_IP=192.168.x.x
ZK_PORT=4370
ZK_PASSWORD=0
ZK_TIMEOUT=120
# Capacidad máxima del log del dispositivo (ZK K30: ~80000-100000)
ZK_CAPACIDAD_MAX=80000

# ── Analytics e IA — Fase 5 ───────────────────────────────────────────────
# Clave API de DeepSeek para reportes narrativos generados por IA.
# Sin esta clave el sistema usa el generador de texto basado en reglas (fallback).
# El fallback es completamente funcional para uso operativo normal.
# Obtener en: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
