# ══════════════════════════════════════════════════
# Copiar este archivo como .env y rellenar los valores
# El archivo .env NO debe subirse al repositorio
# ══════════════════════════════════════════════════

# ── Información del Sistema ────────────────────────
NOMBRE_SISTEMA=Informes Biométricos
NOMBRE_INSTITUCION=NOMBRE_INSTITUCION

# ── Dispositivo biométrico ZK ──────────────────────
ZK_IP=IP_ADDRESS
ZK_PORT=4370
ZK_PASSWORD=PASSWORD
ZK_TIMEOUT=120
# Usar UDP en lugar de TCP (más rápido en red local, probar antes de activar)
ZK_UDP=false
# Capacidad máxima del dispositivo ZK K30 (Rango típico: 80000 - 100000)
ZK_CAPACIDAD_MAX=80000

# ── Sincronización automática ──────────────────────
# SYNC_AUTO=true activa el scheduler de fondo
SYNC_AUTO=false
# Hora del sync nocturno diario (formato HH:MM)
SYNC_HORA_NOCTURNA=00:30
# Intervalo del sync periódico durante la jornada (minutos)
SYNC_INTERVALO_MIN=480

# ── Rutas de datos (dentro del contenedor Docker) ──
DATA_DIR=/data
UPLOAD_FOLDER=/data/uploads
REPORTS_FOLDER=/data/reports

# ── PostgreSQL ─────────────────────────────────────
POSTGRES_USER=asistencias_user
POSTGRES_PASSWORD=cambiar_esto_en_produccion
POSTGRES_DB=asistencias_db
DATABASE_URL=postgresql://asistencias_user:cambiar_esto_en_produccion@db:5432/asistencias_db

# Tenant activo en esta instalación (slug del schema en PostgreSQL)
TENANT_DEFAULT=istpet

# Clave AES-256 para cifrar contraseñas de dispositivos ZK en la BD
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=generar_clave_aleatoria_con_comando_de_arriba

# ── Flask ──────────────────────────────────────────
# Cambiar por una clave aleatoria y segura en producción
FLASK_SECRET_KEY=cambiar_esto_por_una_clave_larga_y_segura
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
# Nunca activar debug en producción (Docker)
FLASK_DEBUG=false

# ── Autenticación de acceso ─────────────────────────
# Dejar vacío para deshabilitar la autenticación (modo desarrollo)
# Para generar el hash: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('tu_clave'))"
APP_PASSWORD_HASH=
# Clave separada para operaciones sensibles como limpiar el dispositivo
APP_MAINTENANCE_PASSWORD_HASH=

# ── Correo electrónico (SMTP) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notificaciones@tuinstituto.edu.ec
# Si usa Gmail/Outlook, se recomienda usar una Contraseña de Aplicación (App Password)
SMTP_PASSWORD=tu_contraseña_o_app_password
SMTP_FROM=notificaciones@tuinstituto.edu.ec
# true para puerto 587 con STARTTLS; false para 465 con SSL directo
SMTP_USE_TLS=true
